import Link from 'next/link';
import { Race } from '@/lib/types';

export default function RaceCard({ race }: { race: Race }) {
  return (
    <Link href={`/races/${race.id}`} className="card">
      <div style={{display:'flex', justifyContent:'space-between'}}>
        <div>
          <h3 style={{margin:'0 0 8px', fontSize:22}}>{race.title}</h3>
          <p className="muted" style={{margin:0}}>締切 {race.deadline}</p>
        </div>
        <span className="badge">{race.status === 'before' ? '発売中' : race.status}</span>
      </div>
    </Link>
  );
}
