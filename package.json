export type Racer = {
  frame: number;
  name: string;
  nationalRate: number;
  localRate: number;
  st: number;
  motorRate: number;
  boatRate: number;
  exhibition: number;
};

export type Bet = { combo: string; probability: number; odds: number; ev: number; judge: string };

export const venues = ['桐生','戸田','江戸川','平和島','多摩川','浜名湖','蒲郡','常滑','津','三国','びわこ','住之江','尼崎','鳴門','丸亀','児島','宮島','徳山','下関','若松','芦屋','福岡','唐津','大村'];

export function defaultRacers(): Racer[] {
  return Array.from({ length: 6 }, (_, i) => ({
    frame: i + 1,
    name: `${i + 1}号艇`,
    nationalRate: 5 + (6 - i) * 0.15,
    localRate: 5,
    st: 0.16 + i * 0.01,
    motorRate: 30,
    boatRate: 30,
    exhibition: 6.75 + i * 0.03,
  }));
}

export function scoreRacer(r: Racer): number {
  const frameBonus = [18, 10, 6, 2, -3, -7][r.frame - 1] ?? 0;
  const stScore = Math.max(0, (0.25 - r.st) * 100);
  const exScore = Math.max(0, (7.05 - r.exhibition) * 30);
  return r.nationalRate * 9 + r.localRate * 4 + r.motorRate * 0.35 + r.boatRate * 0.18 + stScore + exScore + frameBonus;
}

export function probabilities(racers: Racer[]) {
  const scores = racers.map(scoreRacer);
  const total = scores.reduce((a, b) => a + Math.max(1, b), 0);
  return racers.map((r, i) => ({ ...r, score: scores[i], win: Math.max(1, scores[i]) / total }));
}

export function makeTrifecta(racers: Racer[], oddsMap: Record<string, number> = {}): Bet[] {
  const ps = probabilities(racers);
  const out: Bet[] = [];
  for (const a of ps) for (const b of ps) for (const c of ps) {
    if (a.frame === b.frame || a.frame === c.frame || b.frame === c.frame) continue;
    const p = a.win * (b.win / (1 - a.win)) * (c.win / (1 - a.win - b.win));
    const combo = `${a.frame}-${b.frame}-${c.frame}`;
    const odds = oddsMap[combo] ?? autoOdds(p);
    const ev = p * odds * 100;
    out.push({ combo, probability: p, odds, ev, judge: ev >= 120 ? '買い候補' : ev >= 100 ? '注意' : '見送り' });
  }
  return out.sort((x, y) => y.ev - x.ev);
}

function autoOdds(p: number) {
  return Math.max(3, Math.round((0.78 / Math.max(0.001, p)) * 10) / 10);
}
