import Link from'next/link';import{Venue}from'@/lib/types';export default function VenueCard({venue}:{venue:Venue}){return <Link href={`/venues?venue=${venue.id}`} className='card'><div className='row' style={{justifyContent:'space-between'}}><h3 style={{margin:0,fontSize:22}}>{venue.name}</h3><span className='badge'>{venue.isOpenToday?'本日開催':'休み'}</span></div><p className='muted'>{venue.region}</p><p className='muted'>{venue.weather.condition} / 風{venue.weather.windSpeed}m / 波{venue.weather.waveHeight}cm</p></Link>}
