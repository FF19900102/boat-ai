import { Prediction, Racer } from './types';

function laneBonus(lane: number) {
  const bonus: Record<number, number> = { 1: 18, 2: 7, 3: 4, 4: 1, 5: -3, 6: -6 };
  return bonus[lane] ?? 0;
}

function classBonus(className: string) {
  if (className === 'A1') return 8;
  if (className === 'A2') return 4;
  if (className === 'B1') return 0;
  return -3;
}

export function predictRace(racers: Racer[]): Prediction[] {
  const raw = racers.map((r) => {
    const stScore = Math.max(0, (0.24 - r.avgST) * 120);
    const exhibitionScore = Math.max(0, (6.95 - r.exhibitionTime) * 35);
    const score =
      r.nationalWinRate * 8 +
      r.localWinRate * 4 +
      r.motorRate * 0.35 +
      r.boatRate * 0.15 +
      stScore +
      exhibitionScore +
      laneBonus(r.lane) +
      classBonus(r.className);

    return { racer: r, score: Math.max(1, score) };
  });

  const total = raw.reduce((sum, item) => sum + item.score, 0);

  return raw
    .map(({ racer, score }) => {
      const firstRate = (score / total) * 100;
      return {
        lane: racer.lane,
        name: racer.name,
        score: Math.round(score * 10) / 10,
        firstRate: Math.round(firstRate * 10) / 10,
        top2Rate: Math.min(95, Math.round(firstRate * 1.75 * 10) / 10),
        top3Rate: Math.min(99, Math.round(firstRate * 2.45 * 10) / 10)
      };
    })
    .sort((a, b) => b.firstRate - a.firstRate);
}
