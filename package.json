import {Bet,Racer,RaceMeta} from './types'
const clamp=(n:number,min:number,max:number)=>Math.max(min,Math.min(max,n))
export function scoreRacer(r:Racer,meta:RaceMeta){
  const laneBonus={1:18,2:8,3:4,4:0,5:-5,6:-9}[r.lane]??0
  const win=r.nationalWin*7+r.localWin*4
  const motor=r.motorRate*.32+r.boatRate*.15
  const st=clamp((0.22-r.avgST)*170, -10, 18)
  const ex=clamp((6.95-r.exhibition)*45, -12, 16)
  const weather= meta.windSpeed>=5 && r.lane===1 ? -5 : meta.windSpeed>=5 && r.lane>=3 ? 3 : 0
  return clamp(50+laneBonus+win+motor+st+ex+weather,1,180)
}
export function probabilities(racers:Racer[],meta:RaceMeta){
  const scores=racers.map(r=>scoreRacer(r,meta)); const total=scores.reduce((a,b)=>a+b,0)||1
  return racers.map((r,i)=>({lane:r.lane,name:r.name,score:Math.round(scores[i]),winProb:scores[i]/total,top2:clamp(scores[i]/total*1.85,0,0.9),top3:clamp(scores[i]/total*2.55,0,0.97)})).sort((a,b)=>b.winProb-a.winProb)
}
export function generateBets(racers:Racer[],meta:RaceMeta,oddsMap:Record<string,number>):Bet[]{
  const probs=probabilities(racers,meta); const map=new Map(probs.map(p=>[p.lane,p.winProb]))
  const lanes=racers.map(r=>r.lane); const bets:Bet[]=[]
  for(const a of lanes)for(const b of lanes)for(const c of lanes){if(a===b||a===c||b===c)continue
    const pa=map.get(a)||0, pb=map.get(b)||0, pc=map.get(c)||0
    const prob=pa*(pb/(1-pa))*0.92*(pc/(1-pa-pb+0.001))*0.78
    const key=`${a}-${b}-${c}`; const odds=Number(oddsMap[key]||0); const ev=odds?prob*odds*100:0
    bets.push({key,prob,odds,ev,judge:ev>=120?'買い候補':ev>=100?'注意':'買わない'})
  }
  return bets.sort((a,b)=>b.ev-a.ev || b.prob-a.prob)
}
export const defaultRacers=():Racer[]=>[1,2,3,4,5,6].map(lane=>({lane,name:`${lane}号艇`,className:'A1',nationalWin:lane===1?6.8:5.2,localWin:lane===1?6.2:5.0,avgST:0.16,motorRate:35,boatRate:32,exhibition:6.82+lane*0.02,tilt:0,weight:52,course:lane}))
