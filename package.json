export type Boat={frame:number;name:string;win:number;local:number;st:number;motor:number;exhibit:number;odds:number};
export type Ticket={ticket:string;prob:number;odds:number;ev:number;rank:string};
export const venues=['桐生','戸田','江戸川','平和島','多摩川','浜名湖','蒲郡','常滑','津','三国','びわこ','住之江','尼崎','鳴門','丸亀','児島','宮島','徳山','下関','若松','芦屋','福岡','唐津','大村'];
export function defaultBoats():Boat[]{return [1,2,3,4,5,6].map(n=>({frame:n,name:`${n}号艇`,win:n===1?6.4:5.2,local:5.0,st:0.16,motor:35,exhibit:6.78+n*0.01,odds:10+n*4}))}
function score(b:Boat){const frame=[18,9,7,5,3,1][b.frame-1]||0;const ex=Math.max(0,(6.95-b.exhibit)*28);const st=Math.max(0,(0.25-b.st)*90);return frame+b.win*8+b.local*4+b.motor*.55+ex+st}
export function probabilities(boats:Boat[]){const scores=boats.map(score);const sum=scores.reduce((a,b)=>a+b,0)||1;return boats.map((b,i)=>({...b,score:scores[i],p1:scores[i]/sum,p2:Math.min(.92,scores[i]/sum*2.05),p3:Math.min(.98,scores[i]/sum*3.0)})).sort((a,b)=>b.p1-a.p1)}
export function trifecta(boats:Boat[]):Ticket[]{const p=probabilities(boats);const map=new Map(p.map(x=>[x.frame,x]));const out:Ticket[]=[];for(const a of boats){for(const b of boats){for(const c of boats){if(a.frame===b.frame||a.frame===c.frame||b.frame===c.frame)continue;const pa=map.get(a.frame)!.p1;const pb=map.get(b.frame)!.p2/2;const pc=map.get(c.frame)!.p3/3;const prob=pa*pb*pc*1.45;const avgOdds=(a.odds+b.odds+c.odds)/3;const odds=Math.max(3,avgOdds*(a.frame===1?0.8:1.8)*(b.frame>3?1.25:1));const ev=prob*odds*100;out.push({ticket:`${a.frame}-${b.frame}-${c.frame}`,prob,odds,ev,rank:ev>=120?'買い候補':ev>=100?'注意':'見送り'});}}}return out.sort((a,b)=>b.ev-a.ev)}
