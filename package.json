import { Boat } from './types';
export function scoreBoat(b:Boat){
  const frameBonus = [0,18,8,4,1,-2,-5][b.frame] ?? 0;
  const stScore = Math.max(0,(0.25-b.avgST)*120);
  const exScore = b.exhibition ? Math.max(0,(7.05-b.exhibition)*35) : 0;
  const score = b.nationalWin*8 + b.localWin*5 + b.motorRate*0.45 + b.boatRate*0.25 + stScore + exScore + frameBonus;
  return Math.max(1, Math.round(score*10)/10);
}
export function calcProbabilities(boats:Boat[]){
  const scored = boats.map(b=>({...b,score:scoreBoat(b)}));
  const total = scored.reduce((s,b)=>s+(b.score||0),0)||1;
  return scored.map(b=>{
    const p1 = (b.score||0)/total*100;
    return {...b,p1:round(p1),p2:round(Math.min(96,p1*1.85+8)),p3:round(Math.min(99,p1*2.45+18))};
  }).sort((a,b)=>(b.p1||0)-(a.p1||0));
}
function round(n:number){return Math.round(n*10)/10}
