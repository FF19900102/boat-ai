'use client';
import {useEffect,useState} from 'react';import {loadResults} from '@/services/storage';import {RaceResult} from '@/types/boat';
export default function ResultHistory(){const[rows,setRows]=useState<RaceResult[]>([]);useEffect(()=>setRows(loadResults().slice(0,10)),[]);return <div className="card"><h3>直近結果</h3><table className="table compact"><thead><tr><th>レース</th><th>結果</th><th>的中</th><th>収支</th></tr></thead><tbody>{rows.map(r=><tr key={r.raceId}><td>{r.raceId}</td><td>{r.result}</td><td>{r.hit?'○':'×'}</td><td className={r.profit>=0?'good':'bad'}>{r.profit}円</td></tr>)}</tbody></table></div>}
