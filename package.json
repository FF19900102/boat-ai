import { Racer, Weather, Trifecta } from './types';

function laneBonus(lane:number){ return ({1:1.25,2:1.03,3:1.00,4:.95,5:.88,6:.78} as Record<number,number>)[lane] ?? 1; }
function clamp(n:number,min:number,max:number){ return Math.max(min,Math.min(max,n)); }

export function boatScore(r:Racer,w:Weather){
  const win = r.nationalWin*8 + r.localWin*5;
  const motor = r.motorRate*.55 + r.boatRate*.25;
  const st = (0.25 - clamp(r.st,0.05,0.25))*120;
  const ex = (6.9 - clamp(r.exhibition,6.45,6.9))*75;
  const weight = (55 - clamp(r.weight,47,60))*0.5;
  const windPenalty = w.windSpeed >= 5 && r.lane === 1 ? -8 : 0;
  const roughBonus = w.wave >= 5 && r.lane >= 4 ? 3 : 0;
  return Math.max(1,(win+motor+st+ex+weight+windPenalty+roughBonus)*laneBonus(r.lane));
}

export function firstProbabilities(racers:Racer[], weather:Weather){
  const scores = racers.map(r=>boatScore(r,weather));
  const total = scores.reduce((a,b)=>a+b,0);
  return racers.map((r,i)=>({ lane:r.lane, score:scores[i], p1:scores[i]/total }));
}

export function placeProbabilities(racers:Racer[], weather:Weather){
  const p1 = firstProbabilities(racers,weather);
  return p1.map(x=>({ lane:x.lane, score:x.score, p1:x.p1, p2:Math.min(.92,x.p1*1.85+.08), p3:Math.min(.98,x.p1*2.55+.16) }));
}

export function trifectaProbability(order:number[], racers:Racer[], weather:Weather){
  const scores = racers.map(r=>({lane:r.lane, s:boatScore(r,weather)}));
  const s1 = scores.find(x=>x.lane===order[0])!.s;
  const t1 = scores.reduce((a,b)=>a+b.s,0);
  const rem2 = scores.filter(x=>x.lane!==order[0]);
  const s2 = rem2.find(x=>x.lane===order[1])!.s;
  const t2 = rem2.reduce((a,b)=>a+b.s,0);
  const rem3 = rem2.filter(x=>x.lane!==order[1]);
  const s3 = rem3.find(x=>x.lane===order[2])!.s;
  const t3 = rem3.reduce((a,b)=>a+b.s,0);
  return (s1/t1)*(s2/t2)*(s3/t3);
}

export function generateTrifectas(racers:Racer[], weather:Weather, oddsMap:Record<string,number> = {}): Trifecta[]{
  const out:Trifecta[]=[];
  for(const a of racers){for(const b of racers){for(const c of racers){
    if(a.lane===b.lane||a.lane===c.lane||b.lane===c.lane) continue;
    const lanes=[a.lane,b.lane,c.lane]; const key=lanes.join('-');
    const probability=trifectaProbability(lanes,racers,weather);
    const odds=oddsMap[key] || Number((1/Math.max(probability,.001)*0.72).toFixed(1));
    const ev=probability*odds*100;
    out.push({key,lanes,probability,odds,ev,label:ev>=120?'買い候補':ev>=100?'注意':'見送り'});
  }}}
  return out.sort((a,b)=>b.ev-a.ev);
}
