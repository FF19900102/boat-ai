'use client';
import {useMemo,useState} from 'react';
import {Boat,defaultBoats,probabilities,trifectaBets,venues} from '../lib/boat';
export default function Page(){const today=new Date().toLocaleDateString('ja-JP');const [venue,setVenue]=useState('浜名湖');const [race,setRace]=useState(1);const [boats,setBoats]=useState<Boat[]>(defaultBoats());const [result,setResult]=useState('');const [pay,setPay]=useState(0);const probs=useMemo(()=>probabilities(boats),[boats]);const bets=useMemo(()=>trifectaBets(boats),[boats]);const best=bets[0];function upd(i:number,k:keyof Boat,v:any){setBoats(bs=>bs.map((b,idx)=>idx===i?{...b,[k]:k==='name'||k==='className'?v:Number(v)}:b))}function save(){const hit=bets.find(b=>b.ticket===result);const profit=hit?pay-100:result?-100:0;const row={date:today,venue,race,result,pay,profit,best:best?.ticket,hit:best?.ticket===result};const old=JSON.parse(localStorage.getItem('boat-ai-results')||'[]');localStorage.setItem('boat-ai-results',JSON.stringify([row,...old]));alert('保存しました')}return <main className="wrap"><div className="header"><div><div className="title">Boat AI</div><div className="sub">確率・期待値・結果検証を重視した競艇AI土台</div></div><span className="pill">{today}</span></div><section className="section"><h2>本日開催場</h2><div className="grid">{venues.map(v=><button key={v} onClick={()=>setVenue(v)} className={`card btn2 ${venue===v?'active':''}`}><b>{v}</b><div className="muted">開催中</div></button>)}</div></section><section className="section card"><h2>{venue} レース選択</h2><div className="row">{Array.from({length:12},(_,i)=>i+1).map(r=><button key={r} onClick={()=>setRace(r)} className={race===r?'btn':'btn2'}>{r}R</button>)}</div></section><section className="section card"><h2>{venue} {race}R 出走表入力</h2><table className="table"><thead><tr><th>艇</th><th>選手</th><th>級</th><th>全国</th><th>当地</th><th>モーター</th><th>ボート</th><th>ST</th><th>展示</th><th>基準オッズ</th></tr></thead><tbody>{boats.map((b,i)=><tr key={b.lane}><td>{b.lane}</td><td><input value={b.name} onChange={e=>upd(i,'name',e.target.value)}/></td><td><input value={b.className} onChange={e=>upd(i,'className',e.target.value)}/></td>{(['national','local','motor','boat','st','exhibition','odds'] as (keyof Boat)[]).map(k=><td key={k}><input type="number" step="0.01" value={b[k] as any} onChange={e=>upd(i,k,e.target.value)}/></td>)}</tr>)}</tbody></table></section><section className="grid section"><div className="card"><h2>各艇確率</h2><table className="table"><thead><tr><th>艇</th><th>1着</th><th>2連対</th><th>3連対</th><th>スコア</th></tr></thead><tbody>{probs.map(p=><tr key={p.lane}><td>{p.lane}</td><td className="good">{(p.winProb*100).toFixed(1)}%</td><td>{(p.top2*100).toFixed(1)}%</td><td>{(p.top3*100).toFixed(1)}%</td><td>{p.score.toFixed(1)}</td></tr>)}</tbody></table></div><div className="card"><h2>AI判定</h2><p>最上位買い目：<b>{best?.ticket}</b></p><p>期待値：<b className={best?.ev>=120?'good':'bad'}>{best?.ev.toFixed(1)}</b></p><p>判定：<b>{best?.ev>=120?'購入候補':'見送り寄り'}</b></p><p className="muted">※現段階は数式AI。今後、速報取得・DB・機械学習に拡張。</p></div></section><section className="section card"><h2>3連単 期待値ランキング</h2><table className="table"><thead><tr><th>買い目</th><th>的中確率</th><th>推定オッズ</th><th>期待値</th><th>判定</th></tr></thead><tbody>{bets.map(b=><tr key={b.ticket}><td><b>{b.ticket}</b></td><td>{(b.prob*100).toFixed(2)}%</td><td>{b.odds.toFixed(1)}</td><td className={b.ev>=120?'good':b.ev<100?'bad':''}>{b.ev.toFixed(1)}</td><td>{b.judge}</td></tr>)}</tbody></table></section><section className="section card"><h2>結果入力・保存</h2><div className="grid"><label>確定3連単<input placeholder="例 1-3-2" value={result} onChange={e=>setResult(e.target.value)}/></label><label>払戻金<input type="number" value={pay} onChange={e=>setPay(Number(e.target.value))}/></label></div><br/><button className="btn" onClick={save}>結果を保存</button></section></main>}
