export type Boat = {
  frame: number;
  racer: string;
  className: string;
  nationalWin: number;
  localWin: number;
  avgSt: number;
  motorRate: number;
  boatRate: number;
  exhibition: number;
  tilt: number;
  weight: number;
  entry: number;
};

export type Prediction = Boat & {
  score: number;
  winProb: number;
  top2Prob: number;
  top3Prob: number;
};

export type Ticket = {
  combo: string;
  prob: number;
  odds: number;
  ev: number;
  judge: '買い候補' | '注意' | '買わない';
};

export type RaceResult = {
  venue: string;
  raceNo: number;
  resultCombo: string;
  payout: number;
  stake: number;
  boughtTickets: string[];
  hit: boolean;
  returnAmount: number;
  profit: number;
  createdAt: string;
};

export const venues = ['桐生','戸田','江戸川','平和島','多摩川','浜名湖','蒲郡','常滑','津','三国','びわこ','住之江','尼崎','鳴門','丸亀','児島','宮島','徳山','下関','若松','芦屋','福岡','唐津','大村'];

export const defaultBoats: Boat[] = Array.from({ length: 6 }, (_, i) => ({
  frame: i + 1,
  racer: `${i + 1}号艇`,
  className: i === 0 ? 'A1' : i < 3 ? 'A2' : 'B1',
  nationalWin: [6.8, 5.7, 5.5, 4.9, 4.6, 4.2][i],
  localWin: [6.4, 5.4, 5.2, 4.8, 4.5, 4.1][i],
  avgSt: [0.14, 0.16, 0.15, 0.17, 0.18, 0.19][i],
  motorRate: [38, 34, 36, 31, 29, 27][i],
  boatRate: [35, 33, 31, 30, 28, 26][i],
  exhibition: [6.72, 6.78, 6.75, 6.81, 6.84, 6.87][i],
  tilt: 0,
  weight: [52, 53, 52, 54, 53, 55][i],
  entry: i + 1,
}));

const frameBonus: Record<number, number> = { 1: 18, 2: 8, 3: 5, 4: 2, 5: -3, 6: -8 };
const classBonus: Record<string, number> = { A1: 10, A2: 5, B1: 0, B2: -4 };

export function calcPredictions(boats: Boat[], windSpeed: number, wave: number): Prediction[] {
  const raw = boats.map((b) => {
    const exhibitScore = Math.max(0, (6.95 - b.exhibition) * 45);
    const stScore = Math.max(0, (0.23 - b.avgSt) * 95);
    const weatherPenalty = b.frame === 1 && windSpeed >= 5 ? -5 : 0;
    const roughPenalty = wave >= 5 && b.frame === 6 ? -3 : 0;
    const score =
      b.nationalWin * 8 +
      b.localWin * 4 +
      b.motorRate * 0.38 +
      b.boatRate * 0.18 +
      exhibitScore +
      stScore +
      (frameBonus[b.entry] ?? frameBonus[b.frame] ?? 0) +
      (classBonus[b.className] ?? 0) +
      weatherPenalty +
      roughPenalty;
    return { ...b, score: Math.max(1, score), winProb: 0, top2Prob: 0, top3Prob: 0 };
  });
  const total = raw.reduce((s, r) => s + r.score, 0);
  return raw
    .map((r) => {
      const winProb = (r.score / total) * 100;
      return { ...r, winProb, top2Prob: Math.min(95, winProb * 1.72), top3Prob: Math.min(99, winProb * 2.28) };
    })
    .sort((a, b) => b.winProb - a.winProb);
}

export function generateTickets(preds: Prediction[], oddsMap: Record<string, number>): Ticket[] {
  const map = new Map(preds.map((p) => [p.frame, p]));
  const frames = [1,2,3,4,5,6];
  const tickets: Ticket[] = [];
  for (const a of frames) for (const b of frames) for (const c of frames) {
    if (a === b || b === c || a === c) continue;
    const pa = map.get(a)!;
    const pb = map.get(b)!;
    const pc = map.get(c)!;
    const combo = `${a}-${b}-${c}`;
    const prob = (pa.winProb / 100) * (pb.top2Prob / 100) * (pc.top3Prob / 100) * 100 * 0.62;
    const odds = oddsMap[combo] || 0;
    const ev = odds > 0 ? prob * odds : 0;
    tickets.push({ combo, prob, odds, ev, judge: ev >= 120 ? '買い候補' : ev >= 100 ? '注意' : '買わない' });
  }
  return tickets.sort((a, b) => b.ev - a.ev || b.prob - a.prob);
}

export function grade(ev: number) {
  if (ev >= 140) return '★★★★★';
  if (ev >= 120) return '★★★★';
  if (ev >= 100) return '★★★';
  if (ev >= 80) return '★★';
  return '★';
}
