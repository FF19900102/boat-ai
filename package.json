export const venues = ['桐生','戸田','江戸川','平和島','多摩川','浜名湖','蒲郡','常滑','津','三国','びわこ','住之江','尼崎','鳴門','丸亀','児島','宮島','徳山','下関','若松','芦屋','福岡','唐津','大村'];
export const races = Array.from({length:12},(_,i)=>`${i+1}R`);
const names=['山田太郎','鈴木一郎','佐藤健二','田中誠','伊藤翔','加藤亮'];
export function makeBoats(venue='浜名湖', race='1R'){
  const seed=(venue.length*7+parseInt(race)*13)%17;
  return Array.from({length:6},(_,i)=>({
    lane:i+1,name:names[i],className:i<2?'A1':i<4?'A2':'B1',national:(6.8-i*.35+(seed%3)*.08).toFixed(2),local:(6.4-i*.28+(seed%5)*.05).toFixed(2),st:(0.13+i*.01+(seed%2)*.005).toFixed(3),motor:(42-i*2+(seed%6)).toFixed(1),boat:(38-i*1.6+(seed%4)).toFixed(1),exhibition:(6.72+i*.03-(seed%3)*.01).toFixed(2),tilt:'0.0',weight:(52+i*.8).toFixed(1),odds:''
  }));
}
