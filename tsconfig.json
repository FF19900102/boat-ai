import { BoatEntry, Ticket, Weather } from "./types";
function clamp(n: number, min: number, max: number) { return Math.max(min, Math.min(max, n)); }
function laneBias(lane: number, weather: Weather) {
  const base = [22, 13, 10, 7, 4, 1][lane - 1] ?? 0;
  const windPenalty = weather.windSpeed >= 5 && lane === 1 ? -7 : 0;
  const outsideWindBonus = weather.windSpeed >= 5 && lane >= 3 ? 3 : 0;
  return base + windPenalty + outsideWindBonus;
}
export function entryScore(e: BoatEntry, weather: Weather) {
  const win = e.nationalWinRate * 8 + e.localWinRate * 5;
  const motor = e.motorRate * 0.65 + e.boatRate * 0.35;
  const st = clamp((0.24 - e.avgST) * 120, -5, 18);
  const ex = clamp((6.95 - e.exhibitionTime) * 60, -5, 18);
  const weight = clamp((53 - e.weight) * 0.6, -4, 5);
  const wave = weather.waveHeight >= 5 && e.lane >= 4 ? 2 : 0;
  return Math.max(1, win + motor + st + ex + weight + wave + laneBias(e.lane, weather));
}
export function probabilities(entries: BoatEntry[], weather: Weather) {
  const scores = entries.map((e) => ({ entry: e, score: entryScore(e, weather) }));
  const total = scores.reduce((s, x) => s + x.score, 0);
  return scores.map((x) => {
    const p1 = x.score / total;
    return {
      lane: x.entry.lane,
      name: x.entry.name,
      score: x.score,
      first: p1,
      top2: clamp(p1 * 1.68, 0, 0.92),
      top3: clamp(p1 * 2.22, 0, 0.98)
    };
  }).sort((a,b)=>b.first-a.first);
}
export function trifectaTickets(entries: BoatEntry[], weather: Weather, oddsMap: Record<string, number>): Ticket[] {
  const probs = probabilities(entries, weather);
  const p = new Map(probs.map((x) => [x.lane, x.first]));
  const tickets: Ticket[] = [];
  for (const a of entries) for (const b of entries) for (const c of entries) {
    if (a.lane === b.lane || a.lane === c.lane || b.lane === c.lane) continue;
    const pa = p.get(a.lane) ?? 0.01;
    const pb = (p.get(b.lane) ?? 0.01) / Math.max(0.001, 1 - pa);
    const pc = (p.get(c.lane) ?? 0.01) / Math.max(0.001, 1 - pa - (p.get(b.lane) ?? 0.01));
    const probability = clamp(pa * pb * pc * 0.72, 0.0001, 0.3);
    const combo = `${a.lane}-${b.lane}-${c.lane}`;
    const odds = oddsMap[combo] || estimateOdds(probability);
    const ev = probability * odds * 100;
    tickets.push({ combo, probability, odds, ev, rank: ev >= 120 ? "買い候補" : ev >= 100 ? "注意" : "買わない" });
  }
  return tickets.sort((a,b)=>b.ev-a.ev);
}
function estimateOdds(prob: number) {
  return Math.round((0.75 / Math.max(prob, 0.001)) * 10) / 10;
}
export function aiComment(topEv: number) {
  if (topEv >= 140) return "強めに買い候補。期待値が出ています。";
  if (topEv >= 120) return "買い候補あり。点数を絞って検討。";
  if (topEv >= 100) return "微妙。オッズ変動待ち。";
  return "見送り推奨。妙味が低いです。";
}
