import { Boat, Prediction, Ticket, Weather } from './types';
const clamp=(v:number,min:number,max:number)=>Math.max(min,Math.min(max,v));
export function scoreBoat(b:Boat,w:Weather){
  const frameBonus=[0,18,9,5,1,-3,-7][b.frame] ?? 0;
  const rate=b.nationalRate*10+b.localRate*6;
  const motor=b.motorRate*.55+b.boatRate*.25;
  const st=(0.28-clamp(b.avgST,.05,.35))*120;
  const ex=(6.95-clamp(b.exhibition,6.45,7.1))*70;
  const windPenalty=w.windSpeed>=5&&b.frame===1?-6:0;
  const outsideBonus=w.windSpeed>=5&&b.frame>=3?2:0;
  return Math.max(1, rate+motor+st+ex+frameBonus+windPenalty+outsideBonus-b.weight*.12+b.tilt*2);
}
export function predict(boats:Boat[], weather:Weather): Prediction[] {
  const raw=boats.map(b=>({b,score:scoreBoat(b,weather)}));
  const exp=raw.map(x=>Math.exp(x.score/28));
  const sum=exp.reduce((a,b)=>a+b,0);
  return raw.map((x,i)=>{
    const win=exp[i]/sum*100;
    return {frame:x.b.frame,name:x.b.name,score:+x.score.toFixed(1),win:+win.toFixed(1),top2:+clamp(win*1.62,0,92).toFixed(1),top3:+clamp(win*2.05,0,98).toFixed(1),label:win>=32?'本命':win>=18?'対抗':win>=10?'穴':'厳しい'};
  }).sort((a,b)=>b.win-a.win);
}
export function makeTickets(preds:Prediction[]): Ticket[]{
  const p=new Map(preds.map(x=>[x.frame,x.win/100]));
  const frames=[1,2,3,4,5,6];
  const tickets:Ticket[]=[];
  for(const a of frames)for(const b of frames)for(const c of frames){
    if(a===b||a===c||b===c)continue;
    const pa=p.get(a)??0, pb=p.get(b)??0, pc=p.get(c)??0;
    const prob=pa*(pb/(1-pa))*(pc/(1-pa-pb))*100;
    const odds=estimateOdds(prob,a,b,c);
    const ev=prob/100*odds*100;
    tickets.push({key:`${a}-${b}-${c}`,probability:+prob.toFixed(2),odds:+odds.toFixed(1),ev:+ev.toFixed(0),judge:ev>=120?'買い候補':ev>=100?'注意':'買わない'});
  }
  return tickets.sort((a,b)=>b.ev-a.ev).slice(0,30);
}
function estimateOdds(prob:number,a:number,b:number,c:number){
  const base=prob<=0?999:78/prob;
  const pop=(a===1?-.8:0)+(b===1?-.25:0)+(a>=4?.7:0)+(b>=5?.8:0)+(c>=5?.4:0);
  return clamp(base+pop,3,450);
}
export function summary(tickets:Ticket[]){
  const best=tickets[0];
  if(!best)return {message:'データ不足',grade:'-'};
  if(best.ev>=140)return {message:`${best.key} を中心に強く検討`,grade:'★★★★★'};
  if(best.ev>=120)return {message:`${best.key} は買い候補`,grade:'★★★★☆'};
  if(best.ev>=100)return {message:'妙味は薄め。少額か見送り',grade:'★★★☆☆'};
  return {message:'見送り推奨',grade:'★☆☆☆☆'};
}
