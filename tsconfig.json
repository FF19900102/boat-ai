'use client';
import { useRef, useState } from 'react';

export function DataManager() {
  const inputRef = useRef<HTMLInputElement>(null);
  const [message, setMessage] = useState('');

  function exportData() {
    const raw = localStorage.getItem('boat-ai-races') || '[]';
    const blob = new Blob([raw], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `boat-ai-history-${new Date().toISOString().slice(0, 10)}.json`;
    a.click();
    URL.revokeObjectURL(url);
    setMessage('履歴をJSONで書き出しました');
  }

  function clearData() {
    if (!confirm('保存済みの成績を削除しますか？')) return;
    localStorage.removeItem('boat-ai-races');
    window.dispatchEvent(new Event('boat-ai-storage-updated'));
    setMessage('保存データを削除しました');
  }

  async function importData(file?: File) {
    if (!file) return;
    try {
      const text = await file.text();
      const parsed = JSON.parse(text);
      if (!Array.isArray(parsed)) throw new Error('形式エラー');
      localStorage.setItem('boat-ai-races', JSON.stringify(parsed));
      window.dispatchEvent(new Event('boat-ai-storage-updated'));
      setMessage(`${parsed.length}件の履歴を読み込みました`);
    } catch {
      setMessage('読み込みに失敗しました');
    }
  }

  return (
    <section className="card">
      <h2>データ管理</h2>
      <p className="small">今はブラウザ保存。後でDBに移行できるようにJSONで出し入れできます。</p>
      <div className="sync-actions">
        <button className="btn secondary" onClick={exportData}>履歴を書き出す</button>
        <button className="btn secondary" onClick={() => inputRef.current?.click()}>履歴を読み込む</button>
        <button className="btn secondary" onClick={clearData}>履歴を削除</button>
      </div>
      <input ref={inputRef} type="file" accept="application/json" style={{ display: 'none' }} onChange={(e) => importData(e.target.files?.[0])} />
      {message && <p className="badge">{message}</p>}
    </section>
  );
}
