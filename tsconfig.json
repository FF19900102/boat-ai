import { Prediction } from "@/lib/types";

export function PredictionTable({ predictions }: { predictions: Prediction[] }) {
  return (
    <div className="card overflow-hidden">
      <div className="p-4 text-lg font-black">AI確率ランキング</div>
      <table className="w-full">
        <thead>
          <tr>
            <th className="th">艇</th><th className="th">選手</th><th className="th">級</th><th className="th">1着率</th><th className="th">2連対</th><th className="th">3連対</th>
          </tr>
        </thead>
        <tbody>
          {predictions.map((p) => (
            <tr key={p.lane}>
              <td className="td font-black">{p.lane}</td>
              <td className="td">{p.name}</td>
              <td className="td">{p.className}</td>
              <td className="td font-bold">{p.winRate.toFixed(1)}%</td>
              <td className="td">{p.top2Rate.toFixed(1)}%</td>
              <td className="td">{p.top3Rate.toFixed(1)}%</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  );
}
