export function yen(n:number){return `${Math.round(n).toLocaleString('ja-JP')}円`}
export function pct(n:number){return `${Number(n).toFixed(1)}%`}
export function laneColor(lane:number){return `lane lane${lane}`}
export function todayLabel(){return new Date().toLocaleDateString('ja-JP',{year:'numeric',month:'2-digit',day:'2-digit',weekday:'short'})}
